# Copy to .env before starting the stack:   cp .env.example .env
# These are LOCAL DEMO values only — never commit real credentials, and
# change the password if this stack is ever reachable beyond your machine.
POSTGRES_DB=fullstackdb
POSTGRES_USER=fullstack_user
POSTGRES_PASSWORD=local-demo-password
# Frontend (Nginx) is the primary entry point.
FRONTEND_HOST_PORT=8080
# Direct backend port, useful for debugging only.
BACKEND_HOST_PORT=8081
