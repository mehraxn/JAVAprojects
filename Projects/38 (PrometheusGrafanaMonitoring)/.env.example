# Copy to .env before starting the stack:   cp .env.example .env
# The password below is a LOCAL DEMO value (Grafana on localhost only).
# Change it if you expose Grafana beyond your machine. Never commit real secrets.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=local-demo-password
APP_HOST_PORT=8080
PROMETHEUS_HOST_PORT=9090
GRAFANA_HOST_PORT=3000
