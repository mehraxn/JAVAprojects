# Example only. Review base-image digest and build provenance before use.
FROM eclipse-temurin:21-jdk AS build
WORKDIR /workspace
COPY src ./src
RUN javac -d out src/securecicdpipeline/*.java

FROM eclipse-temurin:21-jre-alpine
WORKDIR /app
COPY --from=build /workspace/out ./out
USER 10001
CMD ["java", "-cp", "out", "securecicdpipeline.Main"]

