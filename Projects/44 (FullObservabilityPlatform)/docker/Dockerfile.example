# Image for the observable Java app. Built by ../docker-compose.yml as
# observable-java-app:0.1.0. Compiles the dependency-free app and runs it as a
# non-root user. The app emits Prometheus metrics, JSON logs, and W3C trace
# context (trace_id/span_id) for log correlation.
FROM eclipse-temurin:21-jdk AS build
WORKDIR /workspace
COPY src ./src
RUN javac -d out src/fullobservabilityplatform/*.java

FROM eclipse-temurin:21-jre-alpine
WORKDIR /app
COPY --from=build /workspace/out ./out
RUN addgroup -S app && adduser -S -G app -u 10001 app \
 && mkdir -p /var/log/app && chown -R 10001:app /var/log/app

USER 10001
EXPOSE 8080

ENV APP_PORT=8080 \
    APP_ENV=dev \
    APP_LOG_FILE=/var/log/app/app.log \
    OTEL_SERVICE_NAME=observable-java-app

ENTRYPOINT ["java", "-cp", "out", "fullobservabilityplatform.Main"]
