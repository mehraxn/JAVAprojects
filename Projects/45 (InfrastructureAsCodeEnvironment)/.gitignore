# Never commit real state, credentials, or the concrete inventory.
# Only the *.example files in this project are tracked.
# NOTE: gitignore comments must be on their OWN line — a "#" after a pattern
# becomes part of the pattern and silently breaks the ignore rule.

# --- Terraform ---
**/.terraform/
**/.terraform.lock.hcl
*.tfstate
*.tfstate.*
# keep terraform.tfvars.example, ignore the real one
*.tfvars
!*.tfvars.example
# real backend config; keep backend.tf.example
backend.tf
crash.log

# --- Ansible ---
# keep inventory.ini.example, ignore the real generated one
inventory.ini
*.retry
vault-password*
*.vault

# --- Python ---
__pycache__/
*.pyc
