# SAFE EXAMPLE for the DEV environment. Copy to terraform.tfvars (git-ignored).
# No secrets or real IPs — ever. See docs/security-notes.md.
project_name      = "iac-lab"
region            = "example-region-1"
instance_count    = 1
instance_size     = "small"
allowed_ssh_cidrs = ["192.0.2.0/24"] # RFC 5737 documentation range
