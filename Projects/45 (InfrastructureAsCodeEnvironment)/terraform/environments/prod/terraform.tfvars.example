# SAFE EXAMPLE for the PROD environment. Copy to terraform.tfvars (git-ignored).
# No secrets or real IPs — ever. See docs/security-notes.md.
project_name      = "iac-lab"
region            = "example-region-1"
instance_count    = 3
instance_size     = "large"
allowed_ssh_cidrs = ["198.51.100.10/32"] # RFC 5737 documentation range
