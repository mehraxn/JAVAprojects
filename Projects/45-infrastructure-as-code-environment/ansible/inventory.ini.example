# SAFE EXAMPLE inventory (dev). This mirrors what scripts/generate-inventory.py
# produces from Terraform's `ansible_hosts` output. Every host uses an RFC 1918
# private IP placeholder — no real address, no secrets.
#
# PREFERRED workflow: generate the real inventory instead of copying this file:
#   terraform -chdir=terraform/environments/dev output -json ansible_hosts \
#     > /tmp/ansible_hosts.json
#   python3 scripts/generate-inventory.py /tmp/ansible_hosts.json ansible/inventory.ini
#
# Or, for a quick local test without Terraform, generate from the bundled sample:
#   python3 scripts/generate-inventory.py \
#     examples/terraform-output/ansible_hosts.dev.json ansible/inventory.ini
#
# The concrete inventory.ini is git-ignored; only this .example is tracked.

[app]
iac-lab-dev-app-0 ansible_host=10.10.1.10 ansible_user=ubuntu environment=dev

[app:vars]
app_environment=dev
# Never store a password/private key here. Use an SSH agent or --key-file at run
# time, and ansible-vault for any secret variables (see docs/state-and-secrets.md).
